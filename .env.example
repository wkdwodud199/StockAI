# === KIS Credentials ===
# C:\Users\wkdwo\OneDrive\Desktop\MTS_API.txt 의 키를 이 파일을 복사한 .env 에 옮겨 적으세요.
# scripts\migrate_secrets.ps1 로 자동 마이그레이션도 가능합니다.
# 실거래 키는 절대 커밋되지 않아야 합니다.

# --- 실전 거래 (실물) ---
KIS_REAL_APP_KEY=
KIS_REAL_APP_SECRET=
KIS_REAL_ACCOUNT_NO=
KIS_REAL_ACCOUNT_PRODUCT_CODE=01

# --- 모의 거래 (국내/해외 주식 공용 — 계좌번호 50187113) ---
KIS_MOCK_DOMESTIC_APP_KEY=
KIS_MOCK_DOMESTIC_APP_SECRET=
KIS_MOCK_DOMESTIC_ACCOUNT_NO=50187113
KIS_MOCK_DOMESTIC_ACCOUNT_PRODUCT_CODE=01

# --- 모의 거래 (선물옵션 — 계좌번호 60042662) ---
KIS_MOCK_FUTURES_APP_KEY=
KIS_MOCK_FUTURES_APP_SECRET=
KIS_MOCK_FUTURES_ACCOUNT_NO=60042662
KIS_MOCK_FUTURES_ACCOUNT_PRODUCT_CODE=03

# === LLM Provider for TradingAgents ===
# anthropic | openai | ollama
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# === UI ===
# 실전 거래 메뉴 잠금 해제용 4자리 PIN
REAL_MODE_PIN=0000

# === Mobile API ===
# Flutter 앱 → FastAPI 백엔드 인증 (랜덤 32+ 글자)
MOBILE_API_TOKEN=
# 백엔드 기본 포트
API_PORT=8765
